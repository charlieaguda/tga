# Copy to .env and fill in. Never commit .env.

# Postgres connection. Local dev: matches scripts/dev-db.mjs defaults.
# Production (Neon): use the POOLED connection string here.
DATABASE_URL="postgresql://postgres:tga-dev-only@localhost:5502/tga"

# Auth (email + password accounts, managed by Admin in /admin/users)
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google Drive service account key JSON, base64-encoded (server-only, never NEXT_PUBLIC_)
GOOGLE_SA_KEY_JSON=""
# The Shared Drive that holds all client files
DRIVE_SHARED_DRIVE_ID=""

# Resend (email notifications)
RESEND_API_KEY=""
EMAIL_FROM="TGA Workflow <notifications@example.com>"

# Secret header value required by /api/cron/* routes
CRON_SECRET=""
